// Minimal service worker — required by Chrome/Edge/Android so the app
// qualifies as installable and the real "Install" prompt becomes available.
// It does not cache or intercept anything from your Google Sheet / data setup.
self.addEventListener("install", (event) => {
  self.skipWaiting();
});
self.addEventListener("activate", (event) => {
  self.clients.claim();
});
self.addEventListener("fetch", (event) => {
  // Pass-through only — no caching, no interference with any request.
  event.respondWith(fetch(event.request));
});
